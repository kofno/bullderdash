# Bull-der-dash Configuration
#
# This file shows example environment variables for configuration.
# Copy to .env or export these variables in your shell.

# Redis/Valkey Connection
REDIS_ADDR=127.0.0.1:6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0

# Redis Sentinel (optional; enable by setting both master and addrs)
REDIS_SENTINEL_MASTER=
REDIS_SENTINEL_ADDRS=
REDIS_SENTINEL_USERNAME=
REDIS_SENTINEL_PASSWORD=

# Server Configuration
SERVER_PORT=8080

# BullMQ Configuration
QUEUE_PREFIX=bull

# Metrics
METRICS_POLL_SECONDS=10
DASHBOARD_REFRESH_TIMEOUT_SECONDS=30
WORKLOAD_METRICS_ENABLED=false
WORKLOAD_METRICS_POLL_SECONDS=10
WORKLOAD_METRICS_BLOCK_SECONDS=1
WORKLOAD_METRICS_BATCH_SIZE=100
WORKLOAD_METRICS_MAX_JOB_NAMES_PER_QUEUE=100
WORKLOAD_METRICS_START_ID=$

# Logging
LOG_LEVEL=info

